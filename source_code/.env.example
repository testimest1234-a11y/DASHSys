# Runtime
APP_ENV=local
DEBUG=false

# Data
SNAPSHOT_DIR=data/DBSnapshot
SAMPLES_PATH=data/data.json
OUTPUT_DIR=outputs

# Local LLM
LLM_ENABLED=true
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3.5-9b
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_STRICT=true

# API mode
# mock means no network
# real means Adobe sandbox
# record means call real API and save sanitized fixtures
API_MODE=mock
ALLOW_NETWORK=false

# Adobe API, only fill in real mode
ADOBE_BASE_URL=https://platform.adobe.io
ADOBE_IMS_TOKEN_URL=https://ims-na1.adobelogin.com/ims/token/v3
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_IMS_ORG=
# Copy the exact sandbox value from the official credential email.
ADOBE_SANDBOX=

# Evaluation
EVAL_MAX_ROWS=500
EVAL_FAIL_ON_JSON_ERROR=true
